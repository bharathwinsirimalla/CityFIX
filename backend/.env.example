# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cityfix?retryWrites=true&w=majority

# Auth — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Frontend URL for CORS (no trailing slash)
# Local: http://localhost:5173
# Production: https://your-frontend.onrender.com
CLIENT_ORIGIN=http://localhost:5173

# Optional — complaint image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
